{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "项目共享基线。本机覆盖请用 settings.local.json（不进版本控制）。",


  "permissions": {
    "allow": [
      "Bash(invoke:*)",
      "Bash(docker compose:*)",
      "Bash(docker buildx:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(alembic:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(python scripts/check_arm64_wheels.py:*)",
      "Bash(npm run:*)",
      "Bash(npx vite:*)",
      "Bash(npx vitest:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Read(./**)",
      "Glob(./**)",
      "Grep(./**)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)"
    ]
  },

  "env": {
    "PYTHONUTF8": "1",
    "PYTHONDONTWRITEBYTECODE": "1"
  }
}
