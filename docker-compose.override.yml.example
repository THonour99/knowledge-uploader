services:
  nginx:
    ports:
      - "${NGINX_HTTP_PORT:-8080}:80"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./nginx/default.conf:/etc/nginx/conf.d/default.conf:ro

  frontend:
    ports:
      - "${FRONTEND_HTTP_PORT:-5173}:80"
    volumes:
      - ./frontend:/app

  backend-api:
    ports:
      - "${BACKEND_API_HOST:-127.0.0.1}:${BACKEND_API_PORT:-18000}:8000"
    volumes:
      - ./backend:/app

  postgres:
    ports:
      - "${POSTGRES_HOST_PORT:-15432}:5432"

  rabbitmq:
    ports:
      - "${RABBITMQ_HOST_PORT:-15673}:5672"
      - "${RABBITMQ_MANAGEMENT_HOST_PORT:-15672}:15672"

  redis:
    ports:
      - "${REDIS_HOST_PORT:-16379}:6379"

  minio:
    ports:
      - "${MINIO_API_HOST_PORT:-19000}:9000"
      - "${MINIO_CONSOLE_HOST_PORT:-19001}:9001"
