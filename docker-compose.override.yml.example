services:
  nginx:
    ports:
      - "8080:80"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./nginx/default.conf:/etc/nginx/conf.d/default.conf:ro

  frontend:
    ports:
      - "5173:80"
    volumes:
      - ./frontend:/app

  backend-api:
    ports:
      - "8000:8000"
    volumes:
      - ./backend:/app

  postgres:
    ports:
      - "5432:5432"

  rabbitmq:
    ports:
      - "5672:5672"
      - "15672:15672"

  redis:
    ports:
      - "6379:6379"

  minio:
    ports:
      - "9000:9000"
      - "9001:9001"
