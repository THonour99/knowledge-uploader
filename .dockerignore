# ============================================================================
# Knowledge Uploader — 根 .dockerignore
# Docker 构建上下文裁剪：减小镜像、加速构建
# 每个 Dockerfile 旁可有自己的 .dockerignore 做进一步裁剪
# ============================================================================

# ---------------------------------------------------------------------------
# Git
# ---------------------------------------------------------------------------
.git
.gitignore
.gitattributes
.github
.gitlab

# ---------------------------------------------------------------------------
# Claude Code / IDE
# ---------------------------------------------------------------------------
.claude
CLAUDE.md
.vscode
.idea
*.code-workspace
*.iml

# ---------------------------------------------------------------------------
# 环境与密钥
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ---------------------------------------------------------------------------
# 文档（不进容器）
# ---------------------------------------------------------------------------
docs/
knowledge_uploader_docs/
knowledge_platform_design_package/
*.md
!README.md
企业知识库文件贡献与RAGFlow同步平台需求规格说明书*.md

# ---------------------------------------------------------------------------
# Compose / 部署配置
# ---------------------------------------------------------------------------
docker-compose*.yml
docker-compose*.yaml
deploy/
nginx/

# ---------------------------------------------------------------------------
# Python 缓存 / 测试
# ---------------------------------------------------------------------------
__pycache__
*.py[cod]
*.so
*.egg
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
.coverage.*
htmlcov
.hypothesis
.tox
.nox

# Python venv（容器内重建）
.venv
venv
env
ENV

# ---------------------------------------------------------------------------
# Node.js（仅前端构建需要，但走多阶段构建会自己 npm install）
# ---------------------------------------------------------------------------
node_modules
.pnpm-store
.npm
.yarn-integrity
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 构建产物（容器内会重建）
dist
build
.vite
.next
.cache

# ---------------------------------------------------------------------------
# 操作系统
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# 日志 / 临时
# ---------------------------------------------------------------------------
*.log
logs
*.tmp
*.temp
*.bak

# ---------------------------------------------------------------------------
# 数据 / 数据库
# ---------------------------------------------------------------------------
*.db
*.sqlite*
uploads/
storage/
data/

# ---------------------------------------------------------------------------
# 测试 / 报告
# ---------------------------------------------------------------------------
coverage
.eslintcache
.stylelintcache
*.tsbuildinfo

# ---------------------------------------------------------------------------
# 工具配置（仅本机用，容器不需）
# ---------------------------------------------------------------------------
tasks.py
.editorconfig

# ---------------------------------------------------------------------------
# 测试目录（除非 CI 阶段必需）
# ---------------------------------------------------------------------------
# 后端测试不进生产镜像（多阶段构建时只 COPY app/）
**/tests
**/test_*.py
**/*_test.py
**/*.test.ts
**/*.test.tsx
