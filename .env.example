# Application
APP_NAME=knowledge-uploader
APP_ENV=development
APP_BASE_URL=http://localhost
JWT_SECRET=change-me-change-me-change-me-change-me
ENCRYPTION_KEY=RZ1Sw_27VrN9c5Cfsq01qiwViwT6y7jDCuXYn7tgGJY=
PYTHONUTF8=1
PYTHON_IMAGE=python:3.11-slim-bookworm
BACKEND_BUILD_TARGET=runtime
NODE_IMAGE=node:20-alpine
NGINX_IMAGE=nginx:1.25-alpine

# Host ports
NGINX_HTTP_PORT=80
BACKEND_API_HOST=127.0.0.1
BACKEND_API_PORT=18000
FRONTEND_HTTP_PORT=5173
OUTBOX_METRICS_PORT=9101
OPERATIONAL_METRICS_PORT=9102
OPERATIONAL_METRICS_INTERVAL_SECONDS=30

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=15432
POSTGRES_DB=knowledge_uploader
POSTGRES_USER=knowledge
POSTGRES_PASSWORD=knowledge_password
DATABASE_URL=postgresql+asyncpg://knowledge:knowledge_password@postgres:5432/knowledge_uploader
ALEMBIC_DATABASE_URL=postgresql+psycopg://knowledge:knowledge_password@postgres:5432/knowledge_uploader

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_HOST_PORT=15673
RABBITMQ_MANAGEMENT_HOST_PORT=15672
RABBITMQ_USER=knowledge
RABBITMQ_PASSWORD=knowledge_password
CELERY_BROKER_URL=amqp://knowledge:knowledge_password@rabbitmq:5672//

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=16379
REDIS_PASSWORD=
CELERY_RESULT_BACKEND=redis://redis:6379/0
CACHE_REDIS_URL=redis://redis:6379/1

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_API_HOST_PORT=19000
MINIO_CONSOLE_HOST_PORT=19001
MINIO_ACCESS_KEY=knowledge
MINIO_SECRET_KEY=knowledge_password
MINIO_BUCKET=knowledge-files
MINIO_SECURE=false

# Upload
UPLOAD_MAX_FILE_SIZE_BYTES=52428800
UPLOAD_RATE_LIMIT_PER_MINUTE=10
UPLOAD_ALLOWED_EXTENSIONS=pdf,docx,xlsx,pptx,txt,md,csv
UPLOAD_ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.openxmlformats-officedocument.presentationml.presentation,text/plain,text/markdown,text/csv

# RAGFlow
RAGFLOW_BASE_URL=http://ragflow:9380
# Comma-separated, environment-owner approved alternatives for runtime base_url changes.
RAGFLOW_ALLOWED_BASE_URLS=
RAGFLOW_API_KEY=
# Required when RAGFLOW_API_KEY is set. Use only approved test/target Dataset ids.
RAGFLOW_ALLOWED_DATASET_IDS=
RAGFLOW_REQUEST_TIMEOUT=300
RAGFLOW_MAX_RETRY_COUNT=3
RAGFLOW_PARSE_POLL_TIMEOUT_SECONDS=3600

# Auth
AUTH_PROVIDER=local
ALLOW_REGISTER=true
REQUIRE_EMAIL_VERIFICATION=false
ALLOWED_EMAIL_DOMAINS=company.com,corp.company.com
PASSWORD_MIN_LENGTH=8
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
AUTH_LOGIN_RATE_LIMIT_PER_HOUR=20
AUTH_REGISTER_RATE_LIMIT_PER_HOUR=5
AUTH_PASSWORD_RESET_RATE_LIMIT_PER_HOUR=3
AUTH_RESEND_VERIFICATION_RATE_LIMIT_PER_HOUR=3
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_MINUTES=30
JWT_EXPIRE_MINUTES=1440

# AI
AI_ANALYSIS_ENABLED=true
ALLOW_EXTERNAL_LLM=false
LLM_PROVIDER=disabled
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
EMBEDDING_PROVIDER=disabled
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
AI_REQUEST_TIMEOUT=60
AI_MAX_RETRY_COUNT=2
AI_ALLOW_SYNC_WHEN_ANALYSIS_FAILED=true
ENABLE_SUMMARY=true
ENABLE_AUTO_CATEGORY=true
ENABLE_TAG_GENERATION=true
ENABLE_SENSITIVE_DETECTION=true
ENABLE_QUALITY_SCORE=false
ENABLE_OCR=false
ENABLE_SIMILARITY_DETECTION=false

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# Frontend
VITE_API_BASE_URL=/api

# Celery queues
DOCUMENT_QUEUE=document_queue
AI_QUEUE=ai_queue
RAGFLOW_QUEUE=ragflow_queue
NOTIFICATION_QUEUE=notification_queue
